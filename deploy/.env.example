# Public ports for the web panel and API.
KSYLIAN_FRONTEND_PORT=8088
KSYLIAN_BACKEND_PORT=8090

# Host agent endpoint. For Docker on Linux, host.docker.internal is mapped in docker-compose.yml.
KSYLIAN_AGENT_URL=http://host.docker.internal:8765

# Secret shared between backend and host agent. Generate a long random value for production.
KSYLIAN_AGENT_TOKEN=

# Persistent backend storage inside the Docker volume.
KSYLIAN_SETTINGS_PATH=/data/settings.json
KSYLIAN_USERS_PATH=/data/users.json

# Secret used to sign user sessions. Generate a long random value for production.
KSYLIAN_AUTH_SECRET=

# Optional integrations.
CURSEFORGE_API_KEY=
KSYLIAN_GITHUB_TOKEN=

# Build/version metadata shown in the UI and used by the update checker.
KSYLIAN_BUILD_VERSION=dev
KSYLIAN_BUILD_SHA=local
KSYLIAN_RELEASE_REPOSITORY=ProPandaMen/Ksylian
