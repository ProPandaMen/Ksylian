# Secret shared with the backend. Must match KSYLIAN_AGENT_TOKEN in deploy/.env.
KSYLIAN_AGENT_TOKEN=

# Where managed Minecraft servers and backups are stored.
KSYLIAN_SERVER_ROOT=/opt/ksylian/servers
KSYLIAN_BACKUP_DIR=/mnt/hdd/ksylian-backups
KSYLIAN_DATA_DIR=/var/lib/ksylian-agent

# Project files used by the self-update flow.
KSYLIAN_APP_DIR=/opt/ksylian
KSYLIAN_ENV_FILE=/opt/ksylian/deploy/.env
KSYLIAN_COMPOSE_FILE=/opt/ksylian/deploy/docker-compose.yml
